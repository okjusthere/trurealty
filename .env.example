# Payload CMS
PAYLOAD_SECRET=change-me-to-a-random-string

# Database - SQLite file path
# Local: file:./trurealty.db
# Railway: file:/data/trurealty.db (volume mounted at /data)
DATABASE_URI=file:./trurealty.db

# Server URL
# Local: http://localhost:3000
# Railway: https://your-app.up.railway.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Media upload directory (optional, defaults to public/media)
# Railway: /data/media (volume mounted at /data)
# MEDIA_DIR=/data/media

# Port (Railway sets this automatically)
# PORT=3000
